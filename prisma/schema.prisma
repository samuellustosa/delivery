generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  image         String?
  companies     Company[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Company {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique // Ex: meu-delivery
  imageUrl      String?
  description   String?
  phone         String?
  address       String?
  
  // Horários de Funcionamento
  openTime      String?   @default("08:00")
  closeTime     String?   @default("22:00")

  userId        String
  user          User      @relation(fields: [userId], references: [id])
  
  categories    Category[]
  products      Product[]
  orders        Order[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  products  Product[]
}

model Product {
  id          String    @id @default(cuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  isActive    Boolean   @default(true)
  
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])

  orderItems  OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  displayId     Int         @default(autoincrement()) // Número do pedido simples (ex: #101)
  status        OrderStatus @default(PENDING)
  totalValue    Float
  customerName  String
  customerPhone String
  address       String
  paymentMethod String      // Ex: Pix, Cartão, Dinheiro
  
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])
  
  items         OrderItem[]
  createdAt     DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float   // Preço no momento da compra
  
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

enum OrderStatus {
  PENDING
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}